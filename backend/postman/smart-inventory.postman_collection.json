{
  "info": {
    "name": "Smart Inventory API",
    "description": "스마트 학과 기자재 대여 관리 백엔드 API 컬렉션",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "loanId", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "penaltyId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/send-verification-code",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\"\n}"
            },
            "url": "{{baseUrl}}/auth/send-verification-code"
          }
        },
        {
          "name": "POST /auth/verify-code",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"code\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/auth/verify-code"
          }
        },
        {
          "name": "POST /auth/register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"name\": \"홍길동\",\n  \"phone\": \"01012345678\",\n  \"password\": \"Password123!\",\n  \"verificationToken\": \"PASTE_FROM_VERIFY_RESPONSE\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "POST /auth/refresh",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{refreshToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{}" },
            "url": "{{baseUrl}}/auth/refresh"
          }
        }
      ]
    },
    {
      "name": "Loans",
      "item": [
        {
          "name": "POST /loans/scan",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"qrCode\": \"QR001\",\n  \"notes\": \"실습용\"\n}"
            },
            "url": "{{baseUrl}}/loans/scan"
          }
        },
        {
          "name": "POST /loans/:loanId/return",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"notes\": \"반납 완료\"\n}" },
            "url": "{{baseUrl}}/loans/{{loanId}}/return"
          }
        }
      ]
    },
    {
      "name": "Push Notifications",
      "item": [
        {
          "name": "GET /users/push-tokens",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/users/push-tokens"
          }
        },
        {
          "name": "POST /users/push-tokens",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"FCM_DEVICE_TOKEN\",\n  \"platform\": \"ANDROID\"\n}"
            },
            "url": "{{baseUrl}}/users/push-tokens"
          }
        },
        {
          "name": "POST /users/push-test",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"테스트\",\n  \"body\": \"푸시 테스트 메시지\"\n}"
            },
            "url": "{{baseUrl}}/users/push-test"
          }
        },
        {
          "name": "POST /admin/notifications/broadcast",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"연체 안내\",\n  \"body\": \"반납 기한을 확인해주세요\",\n  \"userIds\": [\"{{userId}}\"]\n}"
            },
            "url": "{{baseUrl}}/admin/notifications/broadcast"
          }
        }
      ]
    },
    {
      "name": "Files",
      "item": [
        {
          "name": "POST /files/upload",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": [] },
                { "key": "purpose", "type": "text", "value": "INCIDENT_EVIDENCE" }
              ]
            },
            "url": "{{baseUrl}}/files/upload"
          }
        },
        {
          "name": "GET /files/my",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/files/my"
          }
        },
        {
          "name": "GET /files/all",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/files/all"
          }
        }
      ]
    }
  ]
}
